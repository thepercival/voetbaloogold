{
  "name": "thepercival/voetbaloog",
  "description": "website om voetbal-voorspellingen voor het EK en WK bij te houden",
  "require": {
    "php": ">=8.4",
    "ext-soap": "*"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "vimeo/psalm": "^6.0",
    "psalm/plugin-phpunit": "^0.19"
  },
  "autoload": {
    "psr-4": {
      "TBS\\": "ThirdParties/TBS/library/TBS/",
      "League\\Tactician\\": "ThirdParties/Tactician/src/"
    },
    "psr-0": {
      "Zend_": "ThirdParties/ZendFramework/library/"
    },
    "classmap": [
      "library/"
    ]
  },
  "scripts": {
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "php -S localhost:8002 -t pub_voetbaloog/"
    ],
    "psalm": "XDEBUG_MODE=off vendor/bin/psalm --output-format=phpstorm --show-info=true --no-diff"
  }
}