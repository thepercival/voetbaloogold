function betsread_isEliminated($oPoulePlace) {
	if ($oPoulePlace->getTeam() === null) return false;
	$oPoule = $oPoulePlace->getPoule();
	if ($oPoule->getState() !== Voetbal_Factory::STATE_PLAYED) return false;

	$oToQR = $oPoulePlace->getToQualifyRule();
	// Position 4: no qualify rule → immediately eliminated
	if ($oToQR === null) return true;

	// Position 3: multi-poule rule → eliminated only when full round is done AND team not in next round
	if ($oToQR->getQualifyRule()->getConfigNr() === 1) {
		$oRound = $oPoule->getRound();
		if ($oRound->getState() !== Voetbal_Factory::STATE_PLAYED) return false;
		$oNextRound = $oRound->getCompetitionSeason()->getNextRound($oRound);
		if ($oNextRound === null) return false;
		$oNextRoundTeams = $oNextRound->getTeams();
		$oTeam = $oPoulePlace->getTeam();
		return ($oNextRoundTeams[$oTeam->getId()] === null);
	}

	return false;
}
